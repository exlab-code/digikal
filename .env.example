# Directus API Configuration
# Replace these values with your actual API credentials
DIRECTUS_API_URL=https://your-directus-api-url
DIRECTUS_API_TOKEN=your-api-token-here
DIRECTUS_COLLECTION=your-collection-name


# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Firecrawl API Configuration (optional, used for rate-limited sources)
FIRECRAWL_API_KEY=your-firecrawl-api-key-here

# Email submission inbox
SUBMIT_IMAP_HOST=your-imap-server
SUBMIT_IMAP_USER=eintragen@digikal.org
SUBMIT_IMAP_PASSWORD=your-email-password
